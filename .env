# ===== Flask Configuration =====
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-this

# ===== PostgreSQL Configuration =====
# If you’re using Docker (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/openspot_2022

# If you’re running Postgres locally (uncomment the one you use)
# DATABASE_URL=postgresql+psycopg://youruser:yourpassword@127.0.0.1:5432/openspot_2022

# ===== Server Configuration =====
# Host/Port for local dev
HOST=0.0.0.0
PORT=5000

# ===== CORS (optional, for frontend fetch calls) =====
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
